{
  "name": "milestone",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "contract:test": "cargo test --manifest-path contracts/milestone-vault/Cargo.toml",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:all": "pnpm test && pnpm contract:test",
    "web:build": "pnpm --filter milestone-web build",
    "web:dev": "pnpm --filter milestone-web dev",
    "format": "turbo run format"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
